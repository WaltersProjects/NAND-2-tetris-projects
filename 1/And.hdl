/**
 * And gate:
 * if (a and b) out = 1, else out = 0 
 */
CHIP And {
    IN a, b;
    OUT out;
    
    PARTS:
    /*
    By definition, nand is not and.

    Therefore, to achieve an and gate from a nand gate, we want to negate nand.

    This works because ~~a is equivalent to a (double negation)
    */
    Nand(a=a, b=b, out=na);
    Not(in=na, out=out);
}