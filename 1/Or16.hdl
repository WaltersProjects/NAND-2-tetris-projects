/**
 * 16-bit Or gate:
 * for i = 0, ..., 15:
 * out[i] = a[i] Or b[i] 
 */
CHIP Or16 {
    IN a[16], b[16];
    OUT out[16];

    PARTS:
    /*
    This time, we can use our 16-gates to replicate the or-1 gate
    */
    Not16(in=a, out=nota);
    Not16(in=b, out=notb);
    And16(a=nota, b=notb, out=nout);
    Not16(in=nout, out=out);
}